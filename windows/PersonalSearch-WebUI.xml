<?xml version="1.0" encoding="UTF-8"?>
<!--
  Task Scheduler task: start the PersonalSearch web UI automatically at logon.

  BEFORE IMPORTING, edit the two paths near the bottom (<Command> and
  <WorkingDirectory>) to point at where you put the crawler folder.

  Import: Task Scheduler -> Action -> Import Task... -> pick this file.
  (Or:  schtasks /create /tn "PersonalSearch WebUI" /xml PersonalSearch-WebUI.xml )
-->
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Starts the PersonalSearch web UI (http://localhost:8000) at logon.</Description>
    <URI>\PersonalSearch WebUI</URI>
  </RegistrationInfo>
  <Triggers>
    <LogonTrigger>
      <Enabled>true</Enabled>
    </LogonTrigger>
  </Triggers>
  <Principals>
    <Principal id="Author">
      <LogonType>InteractiveToken</LogonType>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <AllowHardTerminate>true</AllowHardTerminate>
    <StartWhenAvailable>true</StartWhenAvailable>
    <RunOnlyIfNetworkAvailable>true</RunOnlyIfNetworkAvailable>
    <IdleSettings>
      <StopOnIdleEnd>false</StopOnIdleEnd>
      <RestartOnIdle>false</RestartOnIdle>
    </IdleSettings>
    <AllowStartOnDemand>true</AllowStartOnDemand>
    <Enabled>true</Enabled>
    <Hidden>false</Hidden>
    <ExecutionTimeLimit>PT0S</ExecutionTimeLimit>
    <Priority>7</Priority>
    <RestartOnFailure>
      <Interval>PT1M</Interval>
      <Count>3</Count>
    </RestartOnFailure>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <!-- EDIT THESE TWO PATHS -->
      <Command>C:\path\to\crawler\.venv\Scripts\python.exe</Command>
      <Arguments>-m crawler serve --host 0.0.0.0 --port 8000</Arguments>
      <WorkingDirectory>C:\path\to\crawler</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
